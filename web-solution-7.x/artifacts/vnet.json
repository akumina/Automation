{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "metadata": {
        "description": "Location for all resources."
      }
    },
    "vnetName": {
      "type": "string",
      "metadata": {
        "description": "Web app name."
      }
    },
    "vnetNewOrExisting": {
      "type": "string",
      "allowedValues": [
        "new",
        "existing"
      ],
      "metadata": {
        "description": "Create a new VNET or use an existing one."
      }
    },
    "vnetResourceGroup": {
      "type": "string",
      "metadata": {
        "description": "Resource group name for the VNET."
      }
    },
    "vnetPrefix": {
      "type": "string",
      "metadata": {
        "description": "CIDR prefix for the VNET."
      }
    },
    "snetAppManagerName": {
      "type": "string",
      "metadata": {
        "description": "AppManager subnet name."
      }
    },
    "snetAppManagerPrefix": {
      "type": "string",
      "metadata": {
        "description": "AppManager subnet address prefix."
      }
    },
    "snetHeadlessName": {
      "type": "string",
      "metadata": {
        "description": "Headless subnet name."
      }
    },
    "snetHeadlessPrefix": {
      "type": "string",
      "metadata": {
        "description": "Headless subnet address prefix."
      }
    },
    "snetDataName": {
      "type": "string",
      "metadata": {
        "description": "Data subnet name."
      }
    },
    "snetDataPrefix": {
      "type": "string",
      "metadata": {
        "description": "Data subnet address prerix."
      }
    },
    "snetAppManagerFuncName": {
      "type": "string",
      "metadata": {
        "description": "AppManager Function subnet name."
      }
    },
    "snetAppManagerFuncPrefix": {
      "type": "string",
      "metadata": {
        "description": "AppManager Function subnet address prefix."
      }
    },
    "snetVmName": {
      "type": "string",
      "metadata": {
        "description": "Virtual machine subnet name."
      }
    },
    "snetVmPrefix": {
      "type": "string",
      "metadata": {
        "description": "Virtual machine subnet address prefix."
      }
    },
    "snetAiName": {
      "type": "string",
      "metadata": {
        "description": "AI app subnet name."
      }
    },
    "snetAiPrefix": {
      "type": "string",
      "metadata": {
        "description": "AI app subnet address prefix."
      }
    },
    "snetPeopleSyncName": {
      "type": "string",
      "metadata": {
        "description": "PeopleSync function app subnet name."
      }
    },
    "snetPeopleSyncPrefix": {
      "type": "string",
      "metadata": {
        "description": "PeopleSync function app subnet address prefix."
      }
    }
  },
  "variables": {
    "networkSecurityGroupName": "[concat('nsg-', parameters('vnetName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2024-05-01",
      "name": "[variables('networkSecurityGroupName')]",
      "location": "[parameters('location')]",
      "properties": {
        "securityRules": [
          {
            "name": "allow-rdp-3389",
            "properties": {
              "priority": 1000,
              "access": "Allow",
              "direction": "Inbound",
              "destinationPortRange": "3389",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "sourceAddressPrefix": "*",
              "destinationAddressPrefix": "*"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2024-05-01",
      "name": "[parameters('vnetName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('networkSecurityGroupName'))]"
      ],
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "[parameters('vnetPrefix')]"
          ]
        },
        "subnets": [
          {
            "name": "[parameters('snetVmName')]",
            "properties": {
              "addressPrefix": "[parameters('snetVmPrefix')]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('networkSecurityGroupName'))]"
              }
            }
          },
          {
            "name": "[parameters('snetDataName')]",
            "properties": {
              "addressPrefix": "[parameters('snetDataPrefix')]"
            }
          },
          {
            "name": "[parameters('snetAppManagerName')]",
            "properties": {
              "addressPrefix": "[parameters('snetAppManagerPrefix')]",
              "privateEndpointNetworkPolicies": "Disabled",
              "privateLinkServiceNetworkPolicies": "Enabled",
              "delegations": [
                {
                  "name": "appmanagerDelegation",
                  "properties": {
                    "serviceName": "Microsoft.Web/serverfarms"
                  }
                }
              ]
            }
          },
          {
            "name": "[parameters('snetHeadlessName')]",
            "properties": {
              "addressPrefix": "[parameters('snetHeadlessPrefix')]",
              "privateEndpointNetworkPolicies": "Disabled",
              "privateLinkServiceNetworkPolicies": "Enabled",
              "delegations": [
                {
                  "name": "headlessDelegation",
                  "properties": {
                    "serviceName": "Microsoft.Web/serverfarms"
                  }
                }
              ]
            }
          },
          {
            "name": "[parameters('snetAppManagerFuncName')]",
            "properties": {
              "addressPrefix": "[parameters('snetAppManagerFuncPrefix')]",
              "privateEndpointNetworkPolicies": "Disabled",
              "privateLinkServiceNetworkPolicies": "Enabled",
              "delegations": [
                {
                  "name": "funcappDelegation",
                  "properties": {
                    "serviceName": "Microsoft.Web/serverfarms"
                  }
                }
              ]
            }
          },
          {
            "name": "[parameters('snetAiName')]",
            "properties": {
              "addressPrefix": "[parameters('snetAiPrefix')]",
              "privateEndpointNetworkPolicies": "Disabled",
              "privateLinkServiceNetworkPolicies": "Enabled",
              "delegations": [
                {
                  "name": "aiDelegation",
                  "properties": {
                    "serviceName": "Microsoft.Web/serverfarms"
                  }
                }
              ]
            }
          },
          {
            "name": "[parameters('snetPeopleSyncName')]",
            "properties": {
              "addressPrefix": "[parameters('snetPeopleSyncPrefix')]",
              "privateEndpointNetworkPolicies": "Disabled",
              "privateLinkServiceNetworkPolicies": "Enabled",
              "delegations": [
                {
                  "name": "peoplesyncDelegation",
                  "properties": {
                    "serviceName": "Microsoft.Web/serverfarms"
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ],
  "outputs": {
    "vnetNewOrExisting": {
      "type": "string",
      "value": "[ parameters('vnetNewOrExisting')]"
    },
    "vnetResourceGroup": {
      "type": "string",
      "value": "[ parameters('vnetResourceGroup')]"
    }
  }
}