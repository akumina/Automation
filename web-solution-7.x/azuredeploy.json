      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[uri(deployment().properties.templateLink.uri, 'artifacts/web-ai.json')]"
        },
        "parameters": {
          "location": { "value": "[parameters('location')]" },
          "webName": { "value": "[parameters('aiName')]" },
          "webSku": { "value": "[parameters('aiSku')]" },
          "webAppPackageUrl": { "value": "[parameters('aiAppPackageUrl')]" },
          "webAppInstrumentationKey": {
            "value": "[reference('appinsight').outputs.aiAppInstrumentationKey.value]"
          },
          "webAppInsightConnectionString": {
            "value": "[reference('appinsight').outputs.aiAppInsightConnectionString.value]"
          }
