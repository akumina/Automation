    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "name": "peoplesyncfuncapp",
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', 'storage')]",
        "[resourceId('Microsoft.Resources/deployments', 'cosmosdb')]",
        "[resourceId('Microsoft.Resources/deployments', 'appinsight')]",
        "[resourceId('Microsoft.Resources/deployments', 'vnet')]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[uri(deployment().properties.templateLink.uri, 'artifacts/func-peoplesync.json')]"
        },
        "parameters": {
          "location": { "value": "[parameters('location')]" },
          "funcAppName": { "value": "[parameters('peoplesyncFuncAppName')]" },
          "funcAppSku": { "value": "[parameters('peoplesyncFuncAppSku')]" },
          "funcAppPackageUrl": { "value": "[parameters('peoplesyncFuncPackageUrl')]" },
          "funcAppInstrumentationKey": {
            "value": "[reference('appinsight').outputs.peoplesyncFuncInstrumentationKey.value]"
          },
          "funcAppInsightConnectionString": {
            "value": "[reference('appinsight').outputs.peoplesyncFuncInsightConnectionString.value]"
          },
          "cosmosDbAccountName": {
            "value": "[parameters('cosmosDbAccountName')]"
          },
          "storageAccountName": {
            "value": "[parameters('storageAccountName')]"
          }
        }
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
